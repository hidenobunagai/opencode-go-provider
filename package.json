{
  "name": "opencode-go-provider",
  "publisher": "HidenobuNagai",
  "displayName": "OpenCode Go Provider",
  "description": "OpenCode Go Chat Provider for VS Code Copilot Chat",
  "version": "0.1.49",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hidenobunagai/opencode-go-provider"
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1A1A2E",
    "theme": "dark"
  },
  "keywords": [
    "copilot",
    "opencode",
    "chat",
    "kimi",
    "glm",
    "qwen",
    "minimax",
    "deepseek"
  ],
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "opencode-go",
        "displayName": "OpenCode Go",
        "managementCommand": "opencode-go.manage"
      }
    ],
    "languageModelTools": [
      {
        "name": "opencode_go_analyze_image",
        "toolReferenceName": "analyzeImage",
        "displayName": "OpenCode Go Analyze Image",
        "modelDescription": "Analyze an image with the OpenCode Go vision model and return a text description.",
        "userDescription": "Analyze an image using OpenCode Go Vision.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "image_data": {
              "type": "string",
              "description": "Base64-encoded image data URL."
            },
            "prompt": {
              "type": "string",
              "description": "Instruction describing what to analyze in the image."
            }
          },
          "required": [
            "image_data",
            "prompt"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "opencode-go.manage",
        "title": "Manage OpenCode Go API Key",
        "category": "OpenCode Go"
      },
      {
        "command": "opencode-go.toggleDebugLogging",
        "title": "Toggle Debug Logging",
        "category": "OpenCode Go"
      },
      {
        "command": "opencode-go.openDebugLog",
        "title": "Open Debug Log",
        "category": "OpenCode Go"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "check-changelog": "bun scripts/check-changelog.ts",
    "package:vsix": "bun run check-changelog && bun run compile && vsce package --allow-missing-repository",
    "repro:deepseek": "bun scripts/repro-deepseek-identity.mjs",
    "repro:compare": "bun scripts/repro-deepseek-identity.mjs --models deepseek-v4-flash,kimi-k2.6",
    "repro:compare:json": "bun scripts/repro-deepseek-identity.mjs --models deepseek-v4-flash,kimi-k2.6 --json",
    "measure:deepseek": "bun scripts/measure-deepseek-chat-completions.mjs",
    "measure:deepseek:json": "bun scripts/measure-deepseek-chat-completions.mjs --json"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "1.104.0",
    "@vscode/vsce": "^3.9.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.0.0",
    "jest-util": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {}
}
